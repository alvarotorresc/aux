---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Navbar from '../../../../components/Navbar.astro';
import Footer from '../../../../components/Footer.astro';
import { GroupView } from '../../../../features/group/GroupView';
import { supabase } from '../../../../lib/supabase';
import type { Group, Member } from '../../../../lib/types';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/es');
}

const { data: group, error: groupError } = await supabase
  .from('groups')
  .select('*')
  .eq('slug', slug)
  .maybeSingle();

if (groupError || !group) {
  return Astro.redirect('/404');
}

const { data: members } = await supabase
  .from('members')
  .select('*')
  .eq('group_id', group.id)
  .order('created_at', { ascending: true });

const typedGroup = group as Group;
const typedMembers = (members ?? []) as Member[];
---

<BaseLayout title={typedGroup.name} locale="es">
  <Navbar />
  <main>
    <GroupView client:load group={typedGroup} members={typedMembers} locale="es" />
  </main>
  <Footer locale="es" />
</BaseLayout>
