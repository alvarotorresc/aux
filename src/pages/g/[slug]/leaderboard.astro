---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { LeaderboardView } from '../../../features/leaderboard/LeaderboardView';
import { supabase } from '../../../lib/supabase';
import { t } from '../../../i18n';
import type { Group } from '../../../lib/types';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

const { data: group, error: groupError } = await supabase
  .from('groups')
  .select('*')
  .eq('slug', slug)
  .maybeSingle();

if (groupError || !group) {
  return Astro.redirect('/404');
}

const typedGroup = group as Group;

const acceptLang = Astro.request.headers.get('accept-language') ?? '';
const locale = acceptLang.startsWith('es') ? 'es' : 'en';
---

<BaseLayout title={`${t('leaderboard.title', locale)} — ${typedGroup.name}`} locale={locale}>
  <Navbar />
  <main>
    <LeaderboardView client:load group={typedGroup} locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
