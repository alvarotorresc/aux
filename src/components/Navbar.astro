---
import { LogoWithText } from './ui/Logo';
import { ThemeToggle } from './ThemeToggle';
import LanguageToggle from './LanguageToggle.astro';

const currentLocale = Astro.currentLocale ?? 'en';
const homeHref = currentLocale === 'es' ? '/es' : '/';
---

<nav
  class="sticky top-0 z-50 flex items-center justify-between border-b border-border bg-bg px-5 py-4 pt-[max(1rem,env(safe-area-inset-top))]"
>
  <a href={homeHref} aria-label="Aux home">
    <LogoWithText size={28} />
  </a>
  <div class="flex items-center gap-4">
    <LanguageToggle />
    <ThemeToggle client:load />
  </div>
</nav>
