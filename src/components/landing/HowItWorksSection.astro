---
import { t } from '../../i18n';
import type { Locale } from '../../../site.config';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

const steps = [
  {
    num: '1',
    titleKey: 'howItWorks.step1.title' as const,
    descKey: 'howItWorks.step1.desc' as const,
  },
  {
    num: '2',
    titleKey: 'howItWorks.step2.title' as const,
    descKey: 'howItWorks.step2.desc' as const,
  },
  {
    num: '3',
    titleKey: 'howItWorks.step3.title' as const,
    descKey: 'howItWorks.step3.desc' as const,
  },
  {
    num: '4',
    titleKey: 'howItWorks.step4.title' as const,
    descKey: 'howItWorks.step4.desc' as const,
  },
];
---

<section class="mx-auto max-w-[600px] border-t border-border px-5 py-15">
  <h2 class="mb-10 text-center text-2xl font-bold text-text">
    {t('howItWorks.title', locale)}
  </h2>

  <div class="flex flex-col gap-6">
    {
      steps.map((step) => (
        <div class="flex items-start gap-4">
          <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-accent/25 bg-accent-soft font-mono text-sm font-bold text-accent">
            {step.num}
          </div>
          <div>
            <h4 class="mb-1 text-base font-semibold text-text">{t(step.titleKey, locale)}</h4>
            <p class="text-sm leading-relaxed text-text-secondary">{t(step.descKey, locale)}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>
